                                <Button x:Name="S2_FillBtn" Click="S2_FillBtn_Click" Content="Set High Pressure and Fill with CA" Style="{StaticResource BlackButton}"/>
                                <ProgressBar x:Name="S2_FillPrg" Visibility="Collapsed"/>
                            </StackPanel>
                        </StackPanel>

                    </TabItem>
                </TabControl>
            </TabItem>
            <TabItem Header="CA Fill">

