<UserControl x:Class="DDMAutoGUI.CustomWindows.ServicePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DDMAutoGUI.CustomWindows"
             mc:Ignorable="d" 
             d:DesignHeight="450"
             d:DesignWidth="400">
    <Grid>
        <TabControl Grid.Row="1" Grid.Column="1">
            <TabItem Header="Acetone Flush">

                <Grid Margin="12">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.ColumnSpan="2">
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,12">
                            This procedure will flush acetone through the system to remove adhesive and moisture. Read instructions before proceeding.
                        </TextBlock>

                        <StackPanel Orientation="Vertical" Margin="0,0,0,12">
                            <Button x:Name="Flush_DepresBtn" Click="Flush_DepresBtn_Click" Content="Depressurize Both Systems" Style="{StaticResource BlackButton}"/>
                            <ProgressBar x:Name="Flush_DepresPrg" Visibility="Collapsed"/>
                        </StackPanel>
                    </StackPanel>

                    <GroupBox Header="System 1" Grid.Row="1" Grid.Column="0">
                        <StackPanel>
                            <Label Content="Permabond 801"/>

                            <StackPanel Orientation="Vertical">
                                <Button x:Name="Flush_S1_LowPresBtn" Click="Flush_S1_LowPresBtn_Click" Content="Set Low Pressure" Style="{StaticResource BlackButton}"/>
                                <ProgressBar x:Name="Flush_S1_LowPresPrg" Visibility="Collapsed"/>
                            </StackPanel>
                            <StackPanel Orientation="Vertical">
                                <Button x:Name="Flush_S1_PurgeBtn" Click="Flush_S1_PurgeBtn_Click" Content="Timed Purge" Style="{StaticResource BlackButton}"/>
                                <ProgressBar x:Name="Flush_S1_PurgePrg" Visibility="Collapsed"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="System 2" Grid.Row="1" Grid.Column="1">
                        <StackPanel>
                            <Label Content="Permabond 825"/>

                            <StackPanel Orientation="Vertical">
                                <Button x:Name="Flush_S2_LowPresBtn" Click="Flush_S2_LowPresBtn_Click" Content="Set Low Pressure" Style="{StaticResource BlackButton}"/>
                                <ProgressBar x:Name="Flush_S2_LowPresPrg" Visibility="Collapsed"/>
                            </StackPanel>
                            <StackPanel Orientation="Vertical">
                                <Button x:Name="Flush_S2_PurgeBtn" Click="Flush_S2_PurgeBtn_Click" Content="Timed Purge" Style="{StaticResource BlackButton}"/>
                                <ProgressBar x:Name="Flush_S2_PurgePrg" Visibility="Collapsed"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                </Grid>


            </TabItem>
            <TabItem Header="Adhesive Fill">

                <Grid Margin="12">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>


                    <StackPanel Grid.ColumnSpan="2">
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,12">
                            This procedure will fill the system with adhesive. Read instructions before proceeding.
                        </TextBlock>

                        <StackPanel Orientation="Vertical" Margin="0,0,0,12">
                            <Button x:Name="Fill_DepresBtn" Click="Fill_DepresBtn_Click" Content="Depressurize Both Systems" Style="{StaticResource BlackButton}"/>
                            <ProgressBar x:Name="Fill_DepresPrg" Visibility="Collapsed"/>
                        </StackPanel>
                    </StackPanel>

                    <GroupBox Header="System 1" Grid.Row="1" Grid.Column="0">
                        <StackPanel>
                            <Label Content="Permabond 801"/>

                            <StackPanel Orientation="Vertical">
                                <Button x:Name="Fill_S1_DefPresBtn" Click="Fill_S1_DefPresBtn_Click" Content="Set Default Pressure" Style="{StaticResource BlackButton}"/>
                                <ProgressBar x:Name="Fill_S1_DefPresPrg" Visibility="Collapsed"/>
                            </StackPanel>
                            <StackPanel Orientation="Vertical">
                                <Button x:Name="Fill_S1_FillBtn" Click="Fill_S1_FillBtn_Click" Content="Timed Fill" Style="{StaticResource BlackButton}"/>
                                <ProgressBar x:Name="Fill_S1_FillPrg" Visibility="Collapsed"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="System 2" Grid.Row="1" Grid.Column="1">
                        <StackPanel>
                            <Label Content="Permabond 825"/>
                            <StackPanel Orientation="Vertical">
                                <Button x:Name="Fill_S2_DefPresBtn" Click="Fill_S2_DefPresBtn_Click" Content="Set Default Pressure" Style="{StaticResource BlackButton}"/>
                                <ProgressBar x:Name="Fill_S2_DefPresPrg" Visibility="Collapsed"/>
                            </StackPanel>
                            <StackPanel Orientation="Vertical">
                                <Button x:Name="Fill_S2_FillBtn" Click="Fill_S2_FillBtn_Click" Content="Timed Fill" Style="{StaticResource BlackButton}"/>
                                <ProgressBar x:Name="Fill_S2_FillPrg" Visibility="Collapsed"/>
                            </StackPanel>

                        </StackPanel>
                    </GroupBox>

                </Grid>

                
            </TabItem>
        </TabControl>

    </Grid>
</UserControl>
